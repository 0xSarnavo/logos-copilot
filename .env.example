# Copy to .env and edit. Used by docker-compose (server + caddy).
POSTGRES_PASSWORD=logos
DATABASE_URL=postgresql://logos:logos@db:5432/logos_copilot
PUBLIC_DOMAIN=your-name.duckdns.org

# Embedder: hash ($0, deps-free, deterministic) | fastembed (local CPU) | voyage (managed)
EMBEDDER=hash
EMBED_DIM=256                 # MUST match db/schema.sql vector(...) dim
LOCAL_MODEL=BAAI/bge-small-en-v1.5
# VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3-large
# (voyage/fastembed change EMBED_DIM -> update schema + re-embed)

LOGOS_ORGS=logos-co,logos-blockchain,logos-storage,logos-messaging
MAX_AGE_DAYS=365              # skip repos not pushed within this window

# --- Security (safe defaults; server is loopback-only until you opt in) ---
MCP_HOST=127.0.0.1           # bind loopback by default; non-loopback REQUIRES AUTH_TOKEN
MCP_PORT=8000
# AUTH_TOKEN=                 # required to bind a non-loopback host (front with an auth proxy)
# ALLOW_CODE_EXEC=1          # enable logos_verify_snippet (executes code) — OFF unless set
# SANDBOX_CMD=firejail --net=none --read-only=/   # wrap snippet execution in a real sandbox
# DOCTEST_BIN=/opt/logos-doctest/doctest.py       # path to the logos-doctest engine
# LGS_WORKDIR=/srv/logos-workspaces               # confine logos_scaffold project_path under this
# LGS_BIN=/usr/local/bin/lgs                      # path to the logos-scaffold CLI (if not on PATH)
